# Required — PostgreSQL connection string (e.g. from Neon, Supabase, PlanetScale)
DATABASE_URL=postgresql://user:password@host:5432/carbonpulse

# Required — Port for the API server
PORT=3000

# Required — Google Gemini API key for AI insights
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — Google Routes API key for accurate transport distance
GOOGLE_ROUTES_API_KEY=your_google_routes_api_key_here

# Optional — restrict CORS to your Vercel domain in production
ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional — log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Frontend — set to the deployed API URL so the frontend can reach it
# On Vercel this is the same domain (relative /api works), so leave blank
VITE_API_URL=
